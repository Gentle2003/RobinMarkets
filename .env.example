# ─── Robinhood Chain ────────────────────────────────────────────────────────
# Alchemy key for higher rate limits (optional; public RPC used if empty).
ALCHEMY_API_KEY=

# Target network for scripts/app: 4663 (mainnet) | 46630 (testnet) | 31337 (anvil)
CHAIN_ID=46630

# ─── Contract deploy (Foundry) ──────────────────────────────────────────────
# Deployer private key. NEVER commit a real key. Use a throwaway for testnet.
DEPLOYER_PRIVATE_KEY=
# Operator key that submits matched orders on-chain from the order book service.
OPERATOR_PRIVATE_KEY=

# ─── Order book service ─────────────────────────────────────────────────────
ORDERBOOK_PORT=4000
# Optional Postgres for persistence (usernames/traders + comments survive restarts).
# Leave empty to run fully in-memory. On Railway, add a Postgres database and
# reference its connection string here.
DATABASE_URL=

# ─── House market maker (auto-liquidity) ────────────────────────────────────
# When true, the operator continuously posts real, signed, two-sided quotes on
# active markets and tops them up as takers consume them, so client orders fill
# immediately. Needs OPERATOR_PRIVATE_KEY funded with ETH on CHAIN_ID.
RUN_MARKET_MAKER=false
# Collateral backing EACH quote. Keep tiny on a thin testnet wallet so the same
# pool spreads across many markets (0.0005 ≈ two quotes = 0.001 ETH per market).
MM_SPEND_ETH=0.0005
# How many markets to quote (newest first). Empty = all active markets.
MM_MARKETS=
# Price-ladder depth per side (1 = single level; higher = big orders walk deeper).
MM_LEVELS=1
# Half-spread (cents) from fair for the top level, and cents between ladder levels.
MM_SPREAD_CENTS=2
MM_STEP_CENTS=3
# How often to requote / top up, in milliseconds.
MM_INTERVAL_MS=20000
# Hard cap on total WETH the maker will ever commit (safety). Empty = wrap as
# needed up to what the wallet holds. Set below your balance to keep ETH for gas.
MM_MAX_ETH=

# ─── Web app ────────────────────────────────────────────────────────────────
# WalletConnect Cloud project id (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_CHAIN_ID=46630
NEXT_PUBLIC_ORDERBOOK_URL=http://localhost:4000
# $RMS token contract address — leave empty until launch (header shows "CA · soon").
NEXT_PUBLIC_TOKEN_CA=
# Show the local Anvil chain in the wallet network switcher (LOCAL DEV ONLY).
# Leave unset in production so users only see Robinhood Chain Testnet / Mainnet.
NEXT_PUBLIC_ENABLE_ANVIL=

# ─── Deployed contract addresses (filled in after deploy) ───────────────────
NEXT_PUBLIC_CONDITIONAL_TOKENS_ADDRESS=
NEXT_PUBLIC_CTF_EXCHANGE_ADDRESS=
NEXT_PUBLIC_MARKET_FACTORY_ADDRESS=
NEXT_PUBLIC_COLLATERAL_ADDRESS=
